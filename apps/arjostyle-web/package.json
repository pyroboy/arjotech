{
  "name": "@arjotech/arjostyle-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check-rs",
    "check:full": "NODE_OPTIONS='--max-old-space-size=8192' svelte-kit sync && NODE_OPTIONS='--max-old-space-size=8192' svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:unit": "vitest run src/tests --reporter=verbose",
    "test:unit:watch": "vitest src/tests",
    "test:e2e": "playwright test",
    "test:all": "pnpm test:unit && pnpm test:e2e",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.0",
    "@sveltejs/kit": "^2.16.0",
    "@threlte/core": "^8.0.0",
    "@threlte/extras": "^9.0.0",
    "bits-ui": "^1.0.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "drizzle-orm": "^0.38.0",
    "embla-carousel-svelte": "^8.3.0",
    "lucide-svelte": "^0.469.0",
    "mode-watcher": "^0.5.0",
    "qrcode": "^1.5.4",
    "sveltekit-superforms": "^2.19.0",
    "tailwind-merge": "^2.5.2",
    "three": "^0.174.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "vitest": "^2.0.0",
    "@sveltejs/adapter-cloudflare": "^5.1.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/node": "^22.14.0",
    "@types/qrcode": "^1.5.6",
    "@types/three": "^0.174.0",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.30.0",
    "postcss": "^8.4.47",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.4.11",
    "typescript": "^5.5.3",
    "vite": "^5.4.0",
    "wrangler": "^4.76.0"
  }
}
